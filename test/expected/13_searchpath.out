----
-- Regression test to Global Temporary Table implementation
--
-- Test on search_path forced by the extension
--
----
DROP EXTENSION pgtt;
SHOW search_path ;
         search_path          
------------------------------
 "$user", public, pgtt_schema
(1 row)

create schema first_schema;
create schema second_schema;
SET search_path TO "$user",public,pg_catalog,fisrt_schema,second_schema;
SHOW search_path ;
                              search_path                              
-----------------------------------------------------------------------
 "$user", public, pg_catalog, fisrt_schema, second_schema, pgtt_schema
(1 row)

CREATE EXTENSION pgtt;
SHOW search_path ;
                              search_path                              
-----------------------------------------------------------------------
 "$user", public, pg_catalog, fisrt_schema, second_schema, pgtt_schema
(1 row)

SET search_path TO pg_catalog;
SHOW search_path ;
       search_path       
-------------------------
 pg_catalog, pgtt_schema
(1 row)

SET search_path TO public;
SHOW search_path ;
     search_path     
---------------------
 public, pgtt_schema
(1 row)

-- Test only pg_catalog in search_path.
DROP EXTENSION pgtt;
\c - -
SHOW search_path;
   search_path   
-----------------
 "$user", public
(1 row)

SET search_path TO pg_catalog;
SHOW search_path;
 search_path 
-------------
 pg_catalog
(1 row)

CREATE EXTENSION pgtt;
SHOW search_path;
       search_path        
--------------------------
  pgtt_schema, pg_catalog
(1 row)

-- Test the pg_catalog at end of search_path.
DROP EXTENSION pgtt;
\c - -
SET search_path TO "$user", public, pg_catalog;
SHOW search_path;
         search_path         
-----------------------------
 "$user", public, pg_catalog
(1 row)

CREATE EXTENSION pgtt;
SHOW search_path;
               search_path                
------------------------------------------
 "$user", public, pgtt_schema, pg_catalog
(1 row)

-- Test empty search path like set by pg_dump
SELECT pg_catalog.set_config('search_path', '', false);
 set_config 
------------
 
(1 row)

SHOW search_path;
 search_path 
-------------
 
(1 row)

-- Repeated SET search_path in a PL/pgSQL loop. The parse tree of the SET
-- statement is cached and reused at each iteration, the extension must not
-- add its schema to the statement itself. See issue #59.
\c - -
CREATE OR REPLACE FUNCTION test_searchpath_repeated() RETURNS void AS $$
BEGIN
    FOR i IN 1..100 LOOP
        SET search_path = public;
        PERFORM decode(repeat('00', 1024), 'hex');
    END LOOP;
END;
$$ LANGUAGE plpgsql;
SELECT test_searchpath_repeated();
 test_searchpath_repeated 
--------------------------
 
(1 row)

SHOW search_path;
     search_path     
---------------------
 public, pgtt_schema
(1 row)

DROP FUNCTION test_searchpath_repeated();
